{
  "manifest_version": 3,
  "name": "Bifrost Chat",
  "version": "1.4",
  "description": "Chat for Bifrost AI Gateway",
  "permissions": ["storage", "sidePanel"],
  "host_permissions": ["https://*/*"],
  "content_security_policy": {
    "extension_pages": "default-src 'none'; script-src 'self'; style-src 'self' 'unsafe-inline'; connect-src https:; img-src 'self'"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Bifrost Chat",
    "default_icon": {
      "16":  "icon16.png",
      "48":  "icon48.png",
      "128": "icon128.png"
    }
  },
  "side_panel": {
    "default_path": "panel.html"
  },
  "icons": {
    "16":  "icon16.png",
    "48":  "icon48.png",
    "128": "icon128.png"
  }
}
